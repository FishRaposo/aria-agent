# Aria Agent — environment variables
# All provider keys are OPTIONAL. The agent constructs a provider only when
# its key is set. To enable all 3 providers, fill in all 3 keys.

# --- App ---
APP_NAME=aria-agent
ENV=development
LOG_LEVEL=INFO

# --- OpenCode Go (default) ---
# OCG serves 11+ OSS models (Kimi, DeepSeek, MiMo, GLM, Qwen, etc.)
# Get a key at: https://opencode.ai/zen
OPENCODE_GO_API_KEY=your-opencode-go-key

# --- MiniMax direct ---
# For MiniMax-M3 (default session model) and other MiniMax models.
# Get a key at: https://api.minimax.io
MINIMAX_API_KEY=your-minimax-key

# --- OpenAI Codex (OAuth) ---
# For gpt-5.5 access via OAuth. Pro+ plan required.
# Get the token via: openai-codex auth login
OPENAI_CODEX_OAUTH_TOKEN=your-oauth-token

# --- Defaults ---
# Cooperation pattern: cascade (default) | plan_execute_validate | ensemble
DEFAULT_COOPERATION_PATTERN=cascade
