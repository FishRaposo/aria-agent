# Source this file before running aria-agent commands on Termux.
# It sets PYTHONPATH so shared_core is importable without pip install.
#
# Usage:
#   source .env.termux
#   make demo
#   # or directly:
#   PYTHONPATH="$PYTHONPATH" python examples/run_demo.py

export PYTHONPATH="/data/data/com.termux/files/home/work/aria-agent/../operator-shared-core/src:/data/data/com.termux/files/home/work/aria-agent/src${PYTHONPATH:+:$PYTHONPATH}"
export ARIA_DIR="/data/data/com.termux/files/home/work/aria-agent"
export SHARED_CORE_DIR="/data/data/com.termux/files/home/work/aria-agent/../operator-shared-core"
export HERMES_VENV="/data/data/com.termux/files/home/.hermes/hermes-agent/venv"
